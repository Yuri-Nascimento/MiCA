    <property name="styleSheet">
     <string notr="true">/* Base state of the button */
QPushButton {
    background-color: #3498db;
    color: #ffffff;
    font-size: 14px;
    font-weight: bold;
    border-style: solid;
    border-width: 1px;
    border-color: #2980b9;
    border-radius: 6px;
    padding: 6px 12px;
    min-width: 80px;
}

/* Hover state (mouse pointer over the button) */
QPushButton:hover {
    background-color: #2980b9;
    border-color: #2574a9;
}

/* Pressed state (while clicked) */
QPushButton:pressed {
    background-color: #21618c;
    border-style: inset;
}

/* Disabled state */
QPushButton:disabled {
    background-color: #bdc3c7;
    color: #7f8c8d;
    border-color: #95a5a6;
}</string>
